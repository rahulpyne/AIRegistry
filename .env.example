# --- Supabase (primary store) ---
# If SUPABASE_URL / SUPABASE_KEY are unset, the app falls back to LocalJSONStore
# (JSON files under ./data) so it runs and seeds with zero configuration.
SUPABASE_URL=https://ipilidniymwxiezmwypw.supabase.co
# Use the service_role secret (Project Settings -> API) for server-side writes.
SUPABASE_KEY=
# Table names (override only if you changed them in supabase_schema.sql)
SUPABASE_TABLE_ENTRIES=registry_entries
SUPABASE_TABLE_DOCUMENTS=documents
SUPABASE_TABLE_APPROVALS=approvals
# Supabase Storage bucket for uploaded lifecycle documents
SUPABASE_BUCKET=airegistry-documents

# --- App ---
PORT=8000
UPLOAD_FOLDER=./uploads
# Seed the active store with dummy PacifiCan ideas on first run (1/0)
SEED_ON_START=1

# --- Azure (later-stage migration; not required now) ---
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_KEY=
# COSMOS_ENDPOINT=
# COSMOS_KEY=
