# Copy to .env and fill in. Generate secrets with: openssl rand -base64 32
# DO NOT commit the filled .env.

# Budibase core secrets
JWT_SECRET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
REDIS_PASSWORD=
INTERNAL_API_KEY=
COUCHDB_USER=admin
COUCHDB_PASSWORD=

# First-run Budibase admin (optional)
BB_ADMIN_USER_EMAIL=admin@pacifican.gc.ca
BB_ADMIN_USER_PASSWORD=

# --- Cosmos DB for MongoDB (used inside Budibase's MongoDB datasource, NOT by the container) ---
# Get from: Azure Portal > Cosmos DB account > Connection strings > PRIMARY CONNECTION STRING
# Form: mongodb://<acct>:<key>@<acct>.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@<acct>@
COSMOS_MONGO_CONNECTION_STRING=
COSMOS_DB_NAME=airegistry
